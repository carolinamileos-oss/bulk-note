generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Recipe {
  id          String   @id @default(cuid())
  name        String
  category    String   // breakfast, lunch, dinner, snack, pre-workout, post-workout
  description String?
  prepMethod  String?
  servings    Int      @default(1)
  prepTime    Int?     // minutes
  isFavorite  Boolean  @default(false)
  rating      Int?     // 1-5
  opinion     String?  // loved, liked, neutral, disliked
  notes       String?
  wouldChange String?
  bestTime    String?
  wouldRepeat Boolean?
  worthCost   Boolean?
  tags        String?  // JSON array stored as string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients   RecipeIngredient[]
  mealHistory   MealHistory[]
  mealPlanItems MealPlanItem[]
}

model Ingredient {
  id       String  @id @default(cuid())
  name     String  @unique
  category String? // proteins, dairy, fruits, grains, vegetables, fats, etc.
  unit     String  @default("g")
  calories Float   @default(0) // per 100g or per unit
  protein  Float   @default(0)
  carbs    Float   @default(0)
  fat      Float   @default(0)
  costPer  Float   @default(0) // cost per unit/100g

  recipeIngredients RecipeIngredient[]
  substitutesFrom   Substitution[]     @relation("SubstituteFrom")
  substitutesTo     Substitution[]     @relation("SubstituteTo")
}

model RecipeIngredient {
  id           String @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Float
  unit         String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

model MealHistory {
  id          String   @id @default(cuid())
  date        DateTime
  mealType    String   // breakfast, lunch, dinner, snack, etc.
  recipeId    String
  servings    Float    @default(1)
  notes       String?
  wouldRepeat Boolean?
  satisfaction Int?    // 1-5
  createdAt   DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id])
}

model MealPlan {
  id        String   @id @default(cuid())
  name      String
  weekStart DateTime
  weekEnd   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MealPlanItem[]
}

model MealPlanItem {
  id       String   @id @default(cuid())
  planId   String
  recipeId String
  date     DateTime
  mealType String
  servings Float    @default(1)

  plan   MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe Recipe   @relation(fields: [recipeId], references: [id])
}

model ShoppingList {
  id        String   @id @default(cuid())
  name      String
  planId    String?
  createdAt DateTime @default(now())

  items ShoppingListItem[]
}

model ShoppingListItem {
  id           String  @id @default(cuid())
  listId       String
  ingredientId String?
  name         String
  quantity     Float
  unit         String
  estimatedCost Float  @default(0)
  isPurchased  Boolean @default(false)
  category     String?
  usedInCount  Int     @default(1)

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model Substitution {
  id             String  @id @default(cuid())
  ingredientId   String
  substituteId   String
  reason         String?
  similarCalories Boolean @default(false)
  similarProtein  Boolean @default(false)
  similarFunction Boolean @default(false)
  cheaperOption   Boolean @default(false)

  ingredient  Ingredient @relation("SubstituteFrom", fields: [ingredientId], references: [id])
  substitute  Ingredient @relation("SubstituteTo", fields: [substituteId], references: [id])
}
